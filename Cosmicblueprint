<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cosmic Blueprint - Numerology & Astrology Readings by Spencer McGee</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Nunito+Sans:wght@300;400;600;700&display=swap" rel="stylesheet">
  <style>
/* =====================================================
   COSMIC BLUEPRINT - COMPLETE STYLES
   Created by Spencer McGee
   ===================================================== */

:root {
    --color-bg-dark: #0a0a0f;
    --color-bg-medium: #12121a;
    --color-bg-light: #1a1a25;
    --color-bg-card: #1e1e2a;
    --color-primary: #8b5cf6;
    --color-primary-light: #a78bfa;
    --color-primary-dark: #7c3aed;
    --color-secondary: #06b6d4;
    --color-secondary-light: #22d3ee;
    --color-accent: #f59e0b;
    --color-accent-light: #fbbf24;
    --color-success: #10b981;
    --color-warning: #f59e0b;
    --color-error: #ef4444;
    --color-text-primary: #f8fafc;
    --color-text-secondary: #cbd5e1;
    --color-text-muted: #64748b;
    --color-border: rgba(139, 92, 246, 0.2);
    --color-border-light: rgba(255, 255, 255, 0.1);
    --color-gold: #ffd700;
    --gradient-primary: linear-gradient(135deg, #8b5cf6 0%, #06b6d4 100%);
    --gradient-gold: linear-gradient(135deg, #ffd700 0%, #ff8c00 100%);
    --gradient-dark: linear-gradient(180deg, #0a0a0f 0%, #12121a 100%);
    --gradient-card: linear-gradient(145deg, rgba(30, 30, 42, 0.8) 0%, rgba(26, 26, 37, 0.9) 100%);
    --gradient-glow: radial-gradient(ellipse at center, rgba(139, 92, 246, 0.15) 0%, transparent 70%);
    --font-display: 'Cinzel', serif;
    --font-serif: 'Cormorant Garamond', serif;
    --font-sans: 'Nunito Sans', sans-serif;
    --spacing-xs: 0.25rem;
    --spacing-sm: 0.5rem;
    --spacing-md: 1rem;
    --spacing-lg: 1.5rem;
    --spacing-xl: 2rem;
    --spacing-2xl: 3rem;
    --spacing-3xl: 4rem;
    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 12px;
    --radius-xl: 16px;
    --radius-full: 9999px;
    --shadow-sm: 0 2px 4px rgba(0, 0, 0, 0.3);
    --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.4);
    --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.5);
    --shadow-glow: 0 0 30px rgba(139, 92, 246, 0.3);
    --transition-fast: 150ms ease;
    --transition-normal: 300ms ease;
    --transition-slow: 500ms ease;
    --chakra-1: #ff0000;
    --chakra-2: #ff7f00;
    --chakra-3: #ffff00;
    --chakra-4: #00ff00;
    --chakra-5: #00bfff;
    --chakra-6: #4b0082;
    --chakra-7: #9400d3;
}

*, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

html {
    scroll-behavior: smooth;
    font-size: 16px;
}

body {
    font-family: var(--font-sans);
    background: var(--color-bg-dark);
    color: var(--color-text-primary);
    line-height: 1.6;
    min-height: 100vh;
    overflow-x: hidden;
}

.hidden { display: none !important; }

.container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--spacing-lg);
}

.highlight {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

/* Loading Overlay */
.loading-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(10, 10, 15, 0.98);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    backdrop-filter: blur(10px);
}

.loading-content {
    text-align: center;
    max-width: 400px;
}

.loading-spinner {
    width: 80px;
    height: 80px;
    position: relative;
    margin: 0 auto var(--spacing-xl);
}

.loading-spinner::before,
.loading-spinner::after {
    content: '';
    position: absolute;
    border-radius: 50%;
}

.loading-spinner::before {
    width: 100%;
    height: 100%;
    border: 3px solid var(--color-border);
    border-top-color: var(--color-primary);
    animation: spin 1s linear infinite;
}

.loading-spinner::after {
    width: 60%;
    height: 60%;
    top: 20%;
    left: 20%;
    border: 3px solid var(--color-border);
    border-bottom-color: var(--color-secondary);
    animation: spin 0.8s linear infinite reverse;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

.loading-text {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-lg);
}

.loading-steps {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
}

.loading-steps .step {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    transition: var(--transition-normal);
    padding: var(--spacing-xs) 0;
}

.loading-steps .step.active {
    color: var(--color-primary-light);
}

.loading-steps .step.completed {
    color: var(--color-success);
}

.loading-steps .step.completed::before {
    content: '✓ ';
}

/* Hero Section */
.hero-section {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    position: relative;
    padding: var(--spacing-2xl);
    overflow: hidden;
}

.hero-background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
}

.stars {
    position: absolute;
    width: 100%;
    height: 100%;
    background-image:
        radial-gradient(2px 2px at 20px 30px, #ffffff, transparent),
        radial-gradient(2px 2px at 40px 70px, rgba(255,255,255,0.8), transparent),
        radial-gradient(1px 1px at 90px 40px, #ffffff, transparent),
        radial-gradient(2px 2px at 160px 120px, rgba(255,255,255,0.9), transparent),
        radial-gradient(1px 1px at 230px 80px, #ffffff, transparent),
        radial-gradient(2px 2px at 300px 150px, rgba(255,255,255,0.7), transparent),
        radial-gradient(1.5px 1.5px at 350px 200px, #ffffff, transparent),
        radial-gradient(1px 1px at 400px 50px, rgba(255,255,255,0.6), transparent);
    background-size: 500px 300px;
    animation: twinkle 5s ease-in-out infinite;
}

@keyframes twinkle {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.7; }
}

.constellation {
    position: absolute;
    width: 100%;
    height: 100%;
    background: var(--gradient-glow);
    opacity: 0.5;
}

.floating-symbols {
    position: absolute;
    width: 100%;
    height: 100%;
    overflow: hidden;
    opacity: 0.15;
    pointer-events: none;
}

.floating-symbol {
    position: absolute;
    font-size: 2rem;
    animation: float 25s infinite linear;
}

@keyframes float {
    0% { transform: translateY(100vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.5; }
    90% { opacity: 0.5; }
    100% { transform: translateY(-100vh) rotate(360deg); opacity: 0; }
}

.hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 900px;
}

.hero-badge {
    display: inline-block;
    background: rgba(139, 92, 246, 0.2);
    border: 1px solid var(--color-primary);
    padding: var(--spacing-xs) var(--spacing-lg);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-primary-light);
    margin-bottom: var(--spacing-xl);
}

.hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 5rem);
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: var(--spacing-lg);
    text-shadow: 0 0 40px rgba(139, 92, 246, 0.3);
}

.hero-subtitle {
    font-family: var(--font-serif);
    font-size: clamp(1.125rem, 2.5vw, 1.5rem);
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-2xl);
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.8;
}

.cta-buttons {
    display: flex;
    gap: var(--spacing-md);
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: var(--spacing-2xl);
}

.cta-button {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    padding: var(--spacing-md) var(--spacing-2xl);
    border: none;
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: var(--transition-normal);
    text-decoration: none;
}

.cta-button.primary {
    background: var(--gradient-primary);
    color: white;
    box-shadow: var(--shadow-glow);
}

.cta-button.primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 50px rgba(139, 92, 246, 0.5);
}

.cta-button.secondary {
    background: transparent;
    color: var(--color-text-primary);
    border: 2px solid var(--color-border);
}

.cta-button.secondary:hover {
    border-color: var(--color-primary);
    color: var(--color-primary-light);
}

.hero-features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: var(--spacing-md);
    margin-top: var(--spacing-2xl);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
}

.feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-lg);
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: var(--transition-normal);
}

.feature:hover {
    background: rgba(139, 92, 246, 0.2);
    transform: translateY(-3px);
    border-color: var(--color-primary);
}

.feature-icon {
    font-size: 2rem;
}

.feature span:last-child {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    text-align: center;
}

.scroll-indicator {
    position: absolute;
    bottom: var(--spacing-2xl);
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    animation: bounce 2s infinite;
}

.scroll-indicator span {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 2px;
}

.scroll-arrow {
    width: 20px;
    height: 20px;
    border-right: 2px solid var(--color-text-muted);
    border-bottom: 2px solid var(--color-text-muted);
    transform: rotate(45deg);
    margin: var(--spacing-sm) auto 0;
}

@keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-10px); }
    60% { transform: translateX(-50%) translateY(-5px); }
}

/* Input Section */
.input-section {
    padding: var(--spacing-3xl) 0;
    background: var(--gradient-dark);
    position: relative;
}

.input-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-primary), transparent);
}

.section-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
}

.section-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-primary-light);
    margin-bottom: var(--spacing-md);
}

.section-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin-bottom: var(--spacing-md);
}

.section-description {
    font-family: var(--font-serif);
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.8;
}

.numerology-form {
    max-width: 600px;
    margin: 0 auto;
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--spacing-2xl);
    backdrop-filter: blur(10px);
}

.form-group {
    margin-bottom: var(--spacing-xl);
}

.form-group label {
    display: block;
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text-primary);
}

.form-group.optional label {
    color: var(--color-text-secondary);
}

.optional-tag {
    font-weight: 400;
    font-size: 0.875rem;
    color: var(--color-text-muted);
}

.date-inputs, .time-inputs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-sm);
}

.date-inputs select,
.time-inputs select,
.time-inputs input,
.form-group input,
.form-group select,
.form-group textarea {
    width: 100%;
    padding: var(--spacing-md);
    background: var(--color-bg-dark);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-text-primary);
    font-family: var(--font-sans);
    font-size: 1rem;
    transition: var(--transition-fast);
}

.date-inputs select:focus,
.time-inputs select:focus,
.time-inputs input:focus,
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.2);
}

select option {
    background: var(--color-bg-dark);
    color: var(--color-text-primary);
}

.input-hint {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: var(--spacing-xs);
}

.form-divider {
    border: none;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border), transparent);
    margin: var(--spacing-xl) 0;
}

.submit-button {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--spacing-sm);
    background: var(--gradient-primary);
    color: white;
    font-family: var(--font-sans);
    font-size: 1.125rem;
    font-weight: 600;
    padding: var(--spacing-md) var(--spacing-xl);
    border: none;
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: var(--transition-normal);
    margin-top: var(--spacing-xl);
}

.submit-button:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
}

.submit-button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
    transform: none;
}

/* Results Section */
.results-section {
    padding: var(--spacing-3xl) 0;
    background: var(--color-bg-medium);
}

.results-header {
    text-align: center;
    margin-bottom: var(--spacing-3xl);
    padding-bottom: var(--spacing-2xl);
    border-bottom: 1px solid var(--color-border);
}

.results-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-primary-light);
    margin-bottom: var(--spacing-md);
}

.results-name {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: var(--spacing-sm);
}

.results-birthdate {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
}

.results-zodiac {
    display: flex;
    justify-content: center;
    gap: var(--spacing-lg);
    flex-wrap: wrap;
    margin-top: var(--spacing-lg);
}

.zodiac-badge {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    background: rgba(139, 92, 246, 0.2);
    padding: var(--spacing-sm) var(--spacing-lg);
    border-radius: var(--radius-full);
    font-size: 0.9rem;
    border: 1px solid var(--color-border);
}

.zodiac-badge .zodiac-symbol {
    font-size: 1.5rem;
}

.subsection-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    margin-bottom: var(--spacing-lg);
    text-align: center;
}

.subsection-title::after {
    content: '';
    display: block;
    width: 80px;
    height: 3px;
    background: var(--gradient-primary);
    margin: var(--spacing-md) auto 0;
    border-radius: var(--radius-full);
}

.subsection-description {
    text-align: center;
    max-width: 700px;
    margin: 0 auto var(--spacing-2xl);
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
}

/* Core Numbers Grid */
.core-numbers-section {
    margin-bottom: var(--spacing-3xl);
}

.numbers-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-lg);
}

.number-card {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    text-align: center;
    transition: var(--transition-normal);
    cursor: pointer;
    position: relative;
    overflow: hidden;
}

.number-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px;
    background: var(--gradient-primary);
    transform: scaleX(0);
    transition: var(--transition-normal);
}

.number-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-glow);
    border-color: var(--color-primary);
}

.number-card:hover::before {
    transform: scaleX(1);
}

.number-card .number-value {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 700;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    margin-bottom: var(--spacing-sm);
}

.number-card .number-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-xs);
}

.number-card .number-name {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    color: var(--color-text-primary);
    margin-bottom: var(--spacing-sm);
}

.number-card .number-keywords {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-xs);
    margin-top: var(--spacing-md);
}

.number-card .keyword {
    font-size: 0.65rem;
    padding: 3px 10px;
    background: rgba(139, 92, 246, 0.2);
    border-radius: var(--radius-full);
    color: var(--color-primary-light);
}

.number-card.master-number {
    border-color: var(--color-accent);
    box-shadow: 0 0 20px rgba(245, 158, 11, 0.2);
}

.number-card.master-number .number-value {
    background: var(--gradient-gold);
    -webkit-background-clip: text;
    background-clip: text;
}

.number-card.master-number::before {
    background: var(--gradient-gold);
}

.master-badge {
    position: absolute;
    top: var(--spacing-sm);
    right: var(--spacing-sm);
    background: var(--gradient-gold);
    color: #000;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 3px 8px;
    border-radius: var(--radius-full);
}

/* Essence Section */
.essence-section {
    margin-bottom: var(--spacing-3xl);
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
}

.essence-content {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-2xl);
    position: relative;
}

.essence-content::before {
    content: '"';
    position: absolute;
    top: var(--spacing-md);
    left: var(--spacing-lg);
    font-family: var(--font-serif);
    font-size: 4rem;
    color: var(--color-primary);
    opacity: 0.3;
    line-height: 1;
}

.essence-content p {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    line-height: 1.9;
    color: var(--color-text-secondary);
}

.essence-content p:not(:last-child) {
    margin-bottom: var(--spacing-lg);
}

.essence-content strong {
    color: var(--color-text-primary);
}

/* Astrology Section */
.astrology-section {
    margin-bottom: var(--spacing-3xl);
}

.astro-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
}

.astro-card {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    transition: var(--transition-normal);
}

.astro-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-primary);
}

.astro-card-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--color-border-light);
}

.astro-symbol {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    background: var(--gradient-primary);
    flex-shrink: 0;
}

.astro-info h4 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    margin-bottom: var(--spacing-xs);
}

.astro-info .astro-type {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-muted);
}

.astro-details {
    display: grid;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-md);
}

.astro-detail {
    display: flex;
    justify-content: space-between;
    font-size: 0.9rem;
    padding: var(--spacing-xs) 0;
    border-bottom: 1px dotted var(--color-border-light);
}

.astro-detail .label {
    color: var(--color-text-muted);
}

.astro-detail .value {
    color: var(--color-text-primary);
    font-weight: 500;
}

.astro-description {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
}

/* Matrix Section */
.matrix-section {
    margin-bottom: var(--spacing-3xl);
}

.matrix-container {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--spacing-2xl);
    align-items: start;
}

@media (max-width: 900px) {
    .matrix-container {
        grid-template-columns: 1fr;
    }
}

.matrix-visual {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-2xl);
    position: relative;
    min-height: 450px;
    aspect-ratio: 1;
    max-width: 500px;
    margin: 0 auto;
}

.matrix-point {
    position: absolute;
    width: 55px;
    height: 55px;
    background: var(--color-bg-dark);
    border: 2px solid var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 600;
    cursor: pointer;
    transition: var(--transition-normal);
    z-index: 2;
}

.matrix-point:hover {
    transform: scale(1.2);
    background: var(--color-primary);
    color: white;
    box-shadow: var(--shadow-glow);
}

.matrix-point .point-label {
    position: absolute;
    bottom: -24px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.6rem;
    font-family: var(--font-sans);
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-muted);
    white-space: nowrap;
    font-weight: 600;
}

.matrix-point.top { top: 5%; left: 50%; transform: translateX(-50%); }
.matrix-point.top-left { top: 22%; left: 15%; }
.matrix-point.top-right { top: 22%; right: 15%; }
.matrix-point.center { top: 50%; left: 50%; transform: translate(-50%, -50%); }
.matrix-point.left { top: 50%; left: 5%; transform: translateY(-50%); }
.matrix-point.right { top: 50%; right: 5%; transform: translateY(-50%); }
.matrix-point.bottom-left { bottom: 22%; left: 15%; }
.matrix-point.bottom-right { bottom: 22%; right: 15%; }
.matrix-point.bottom { bottom: 5%; left: 50%; transform: translateX(-50%); }

.matrix-lines {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
}

.matrix-lines svg {
    width: 100%;
    height: 100%;
}

.matrix-lines line {
    stroke: var(--color-border);
    stroke-width: 1;
    opacity: 0.5;
}

.matrix-legend {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    max-height: 500px;
    overflow-y: auto;
}

.legend-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    margin-bottom: var(--spacing-lg);
    text-align: center;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-sm) 0;
    border-bottom: 1px solid var(--color-border-light);
    cursor: pointer;
    transition: var(--transition-fast);
}

.legend-item:last-child {
    border-bottom: none;
}

.legend-item:hover {
    background: rgba(139, 92, 246, 0.1);
    margin: 0 calc(-1 * var(--spacing-md));
    padding-left: var(--spacing-md);
    padding-right: var(--spacing-md);
    border-radius: var(--radius-sm);
}

.legend-item .legend-number {
    width: 36px;
    height: 36px;
    background: var(--color-bg-dark);
    border: 1px solid var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.9rem;
    flex-shrink: 0;
}

.legend-item .legend-info {
    flex: 1;
    min-width: 0;
}

.legend-item .legend-position {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 1px;
}

.legend-item .legend-name {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

/* Chakra Section */
.chakra-section {
    margin-bottom: var(--spacing-3xl);
}

.chakra-intro {
    text-align: center;
    max-width: 800px;
    margin: 0 auto var(--spacing-2xl);
}

.chakra-intro p {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
}

.chakra-grid {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
    max-width: 1000px;
    margin: 0 auto;
}

.chakra-card {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    transition: var(--transition-normal);
    position: relative;
    overflow: hidden;
}

.chakra-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 5px;
}

.chakra-card.chakra-7::before { background: var(--chakra-7); }
.chakra-card.chakra-6::before { background: var(--chakra-6); }
.chakra-card.chakra-5::before { background: var(--chakra-5); }
.chakra-card.chakra-4::before { background: var(--chakra-4); }
.chakra-card.chakra-3::before { background: var(--chakra-3); }
.chakra-card.chakra-2::before { background: var(--chakra-2); }
.chakra-card.chakra-1::before { background: var(--chakra-1); }

.chakra-card:hover {
    transform: translateX(5px);
    box-shadow: var(--shadow-lg);
}

.chakra-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
}

.chakra-symbol {
    width: 70px;
    height: 70px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    font-weight: bold;
    color: white;
    flex-shrink: 0;
}

.chakra-7 .chakra-symbol { background: var(--chakra-7); }
.chakra-6 .chakra-symbol { background: var(--chakra-6); }
.chakra-5 .chakra-symbol { background: var(--chakra-5); color: #333; }
.chakra-4 .chakra-symbol { background: var(--chakra-4); color: #333; }
.chakra-3 .chakra-symbol { background: var(--chakra-3); color: #333; }
.chakra-2 .chakra-symbol { background: var(--chakra-2); }
.chakra-1 .chakra-symbol { background: var(--chakra-1); }

.chakra-info h4 {
    font-family: var(--font-display);
    font-size: 1.4rem;
    margin-bottom: var(--spacing-xs);
}

.chakra-sanskrit {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--color-text-muted);
    font-size: 0.95rem;
}

.chakra-location {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin-top: var(--spacing-xs);
}

.chakra-values {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
}

.chakra-value-item {
    background: var(--color-bg-dark);
    border-radius: var(--radius-md);
    padding: var(--spacing-md);
    text-align: center;
}

.chakra-value-label {
    display: block;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-xs);
}

.chakra-value-number {
    display: block;
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 700;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.chakra-value-arcana {
    display: block;
    font-size: 0.7rem;
    color: var(--color-primary-light);
    margin-top: var(--spacing-xs);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.chakra-themes {
    display: flex;
    flex-wrap: wrap;
    gap: var(--spacing-xs);
    margin-bottom: var(--spacing-md);
}

.chakra-theme {
    font-size: 0.7rem;
    padding: 3px 10px;
    background: rgba(139, 92, 246, 0.15);
    border-radius: var(--radius-full);
    color: var(--color-text-secondary);
}

.chakra-meaning {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--color-border-light);
}

.chakra-status {
    display: inline-block;
    padding: var(--spacing-xs) var(--spacing-md);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: var(--spacing-md);
}

.chakra-status.balanced {
    background: rgba(16, 185, 129, 0.2);
    color: var(--color-success);
}

.chakra-status.overactive {
    background: rgba(239, 68, 68, 0.2);
    color: var(--color-error);
}

.chakra-status.underactive {
    background: rgba(245, 158, 11, 0.2);
    color: var(--color-warning);
}

.chakra-totals {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--spacing-lg);
    margin-top: var(--spacing-2xl);
    padding: var(--spacing-xl);
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
}

.chakra-total-item {
    text-align: center;
}

.chakra-total-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-sm);
}

.chakra-total-value {
    font-family: var(--font-display);
    font-size: 2.5rem;
    font-weight: 700;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.chakra-total-meaning {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-top: var(--spacing-xs);
}

/* Reading Tabs */
.detailed-readings {
    margin-bottom: var(--spacing-3xl);
}

.reading-tabs {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-2xl);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid var(--color-border);
}

.tab-button {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
    font-family: var(--font-sans);
    font-size: 0.85rem;
    font-weight: 500;
    padding: var(--spacing-sm) var(--spacing-lg);
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: var(--transition-fast);
}

.tab-button:hover {
    border-color: var(--color-primary);
    color: var(--color-primary-light);
}

.tab-button.active {
    background: var(--gradient-primary);
    border-color: transparent;
    color: white;
}

.tab-contents {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-2xl);
    min-height: 500px;
}

.tab-content {
    display: none;
}

.tab-content.active {
    display: block;
    animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}

/* Tab Content Styling */
.reading-header {
    margin-bottom: var(--spacing-2xl);
    padding-bottom: var(--spacing-xl);
    border-bottom: 1px solid var(--color-border-light);
}

.reading-header h4 {
    font-family: var(--font-display);
    font-size: 2rem;
    margin-bottom: var(--spacing-sm);
}

.reading-header .number-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    background: rgba(139, 92, 246, 0.2);
    padding: var(--spacing-sm) var(--spacing-lg);
    border-radius: var(--radius-full);
    font-size: 0.9rem;
}

.reading-header .number-badge .badge-number {
    font-weight: 700;
    color: var(--color-primary-light);
    font-size: 1.1rem;
}

.reading-intro {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    color: var(--color-text-secondary);
    line-height: 1.9;
    margin-bottom: var(--spacing-xl);
    padding: var(--spacing-lg);
    background: rgba(139, 92, 246, 0.1);
    border-left: 4px solid var(--color-primary);
    border-radius: var(--radius-md);
}

.reading-section {
    margin-bottom: var(--spacing-2xl);
}

.reading-section h5 {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-primary-light);
    margin-bottom: var(--spacing-md);
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
}

.reading-section h5::before {
    content: '';
    width: 8px;
    height: 8px;
    background: var(--color-primary);
    border-radius: 50%;
}

.reading-section p {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.9;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
}

.reading-section ul {
    list-style: none;
    display: grid;
    gap: var(--spacing-sm);
}

.reading-section li {
    position: relative;
    padding-left: var(--spacing-xl);
    color: var(--color-text-secondary);
    line-height: 1.7;
    font-size: 1rem;
}

.reading-section li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--color-primary);
}

.reading-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-lg);
    margin-top: var(--spacing-lg);
}

.reading-card {
    background: var(--color-bg-dark);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
}

.reading-card h6 {
    font-family: var(--font-display);
    font-size: 1rem;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text-primary);
}

.reading-card p {
    font-size: 0.95rem;
    margin-bottom: 0;
}

/* Expandable Sections */
.expandable-section {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    margin-bottom: var(--spacing-md);
    overflow: hidden;
}

.expandable-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--spacing-md) var(--spacing-lg);
    background: rgba(139, 92, 246, 0.1);
    cursor: pointer;
    transition: var(--transition-fast);
}

.expandable-header:hover {
    background: rgba(139, 92, 246, 0.2);
}

.expandable-header h5 {
    margin: 0;
    font-size: 1rem;
    color: var(--color-text-primary);
}

.expandable-header h5::before {
    display: none;
}

.expandable-header .expand-icon {
    font-size: 1.25rem;
    transition: var(--transition-fast);
}

.expandable-section.open .expand-icon {
    transform: rotate(180deg);
}

.expandable-content {
    padding: 0 var(--spacing-lg);
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
}

.expandable-section.open .expandable-content {
    padding: var(--spacing-lg);
    max-height: 5000px;
}

/* Reflection Section */
.reflection-section {
    margin-bottom: var(--spacing-3xl);
    max-width: 900px;
    margin-left: auto;
    margin-right: auto;
}

.reflection-questions {
    display: grid;
    gap: var(--spacing-md);
}

.reflection-question {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-md);
    transition: var(--transition-normal);
}

.reflection-question:hover {
    transform: translateX(5px);
    border-color: var(--color-primary);
}

.question-number {
    width: 36px;
    height: 36px;
    background: var(--gradient-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
}

.question-text {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
}

/* Reviews Section */
.reviews-section {
    padding: var(--spacing-3xl) 0;
    background: var(--color-bg-dark);
}

.reviews-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-2xl);
}

.review-card {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-xl);
    transition: var(--transition-normal);
}

.review-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
}

.review-header {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-md);
}

.review-avatar {
    width: 50px;
    height: 50px;
    border-radius: 50%;
    background: var(--gradient-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.25rem;
}

.review-info h5 {
    font-size: 1rem;
    margin-bottom: var(--spacing-xs);
}

.review-stars {
    color: var(--color-gold);
    font-size: 0.9rem;
}

.review-text {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin-bottom: var(--spacing-md);
    font-style: italic;
}

.review-date {
    font-size: 0.8rem;
    color: var(--color-text-muted);
}

.review-form {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-2xl);
    max-width: 600px;
    margin: 0 auto;
}

.review-form h4 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin-bottom: var(--spacing-lg);
    text-align: center;
}

.star-rating {
    display: flex;
    justify-content: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-lg);
}

.star-rating .star {
    font-size: 2rem;
    cursor: pointer;
    color: var(--color-text-muted);
    transition: var(--transition-fast);
}

.star-rating .star:hover,
.star-rating .star.active {
    color: var(--color-gold);
    transform: scale(1.1);
}

.review-form textarea {
    min-height: 120px;
    resize: vertical;
}

/* Action Buttons */
.action-buttons {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--spacing-md);
    padding-top: var(--spacing-2xl);
    border-top: 1px solid var(--color-border);
}

.action-button {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
    padding: var(--spacing-md) var(--spacing-xl);
    border-radius: var(--radius-md);
    cursor: pointer;
    transition: var(--transition-normal);
}

.action-button.primary {
    background: var(--gradient-primary);
    border: none;
    color: white;
}

.action-button.primary:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-glow);
}

.action-button.secondary {
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-secondary);
}

.action-button.secondary:hover {
    border-color: var(--color-primary);
    color: var(--color-primary-light);
}

/* Compatibility Section */
.compatibility-section {
    padding: var(--spacing-3xl) 0;
    background: var(--color-bg-dark);
}

.compatibility-form {
    max-width: 700px;
    margin: 0 auto;
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--spacing-2xl);
}

.form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
}

@media (max-width: 600px) {
    .form-row {
        grid-template-columns: 1fr;
    }
}

.compatibility-results {
    max-width: 900px;
    margin: var(--spacing-2xl) auto 0;
}

.compatibility-score {
    text-align: center;
    margin-bottom: var(--spacing-2xl);
}

.score-circle {
    width: 180px;
    height: 180px;
    border-radius: 50%;
    background: var(--gradient-card);
    border: 5px solid var(--color-primary);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin: 0 auto var(--spacing-lg);
    position: relative;
}

.score-circle::before {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    border: 5px solid transparent;
    border-top-color: var(--color-secondary);
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.05); opacity: 0.8; }
}

.score-value {
    font-family: var(--font-display);
    font-size: 3.5rem;
    font-weight: 700;
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.score-label {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-text-muted);
}

.compatibility-level {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin-bottom: var(--spacing-sm);
}

.compatibility-description {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    max-width: 600px;
    margin: 0 auto var(--spacing-2xl);
    line-height: 1.7;
}

.compatibility-breakdown {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-2xl);
}

.breakdown-item {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
}

.breakdown-item h5 {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-sm);
}

.breakdown-bar {
    height: 10px;
    background: var(--color-bg-dark);
    border-radius: var(--radius-full);
    overflow: hidden;
    margin-bottom: var(--spacing-sm);
}

.breakdown-fill {
    height: 100%;
    background: var(--gradient-primary);
    border-radius: var(--radius-full);
    transition: width 1s ease;
}

.breakdown-score {
    font-weight: 600;
    color: var(--color-primary-light);
    font-size: 1.1rem;
}

.compatibility-analysis {
    background: var(--gradient-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--spacing-2xl);
}

.compatibility-analysis h4 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    margin-bottom: var(--spacing-lg);
    text-align: center;
}

.compatibility-analysis p {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-lg);
}

/* Footer */
.footer {
    background: var(--color-bg-dark);
    padding: var(--spacing-3xl) 0 var(--spacing-xl);
    border-top: 1px solid var(--color-border);
}

.footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-2xl);
    margin-bottom: var(--spacing-2xl);
}

.footer-brand h3 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    margin-bottom: var(--spacing-sm);
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.footer-brand p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
}

.footer-links h4 {
    font-size: 1rem;
    margin-bottom: var(--spacing-md);
    color: var(--color-text-primary);
}

.footer-links ul {
    list-style: none;
}

.footer-links li {
    margin-bottom: var(--spacing-sm);
}

.footer-links a {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.9rem;
    transition: var(--transition-fast);
}

.footer-links a:hover {
    color: var(--color-primary-light);
}

.footer-bottom {
    text-align: center;
    padding-top: var(--spacing-xl);
    border-top: 1px solid var(--color-border-light);
}

.footer-bottom p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: var(--spacing-sm);
}

.creator-credit {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    margin-top: var(--spacing-lg);
    padding: var(--spacing-md);
    background: rgba(139, 92, 246, 0.1);
    border-radius: var(--radius-md);
    display: inline-block;
}

.creator-credit strong {
    background: var(--gradient-primary);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-size: 1.2rem;
}

/* Modal */
.modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(10, 10, 15, 0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    backdrop-filter: blur(10px);
    padding: var(--spacing-lg);
}

.modal-content {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--spacing-2xl);
    max-width: 700px;
    width: 100%;
    max-height: 85vh;
    overflow-y: auto;
    position: relative;
}

.modal-close {
    position: absolute;
    top: var(--spacing-md);
    right: var(--spacing-md);
    background: none;
    border: none;
    color: var(--color-text-muted);
    font-size: 1.5rem;
    cursor: pointer;
    transition: var(--transition-fast);
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
}

.modal-close:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.1);
}

#modal-body h3 {
    font-family: var(--font-display);
    font-size: 1.75rem;
    margin-bottom: var(--spacing-lg);
}

#modal-body h4 {
    font-family: var(--font-sans);
    font-size: 1.1rem;
    color: var(--color-primary-light);
    margin-top: var(--spacing-lg);
    margin-bottom: var(--spacing-sm);
}

#modal-body p {
    color: var(--color-text-secondary);
    margin-bottom: var(--spacing-md);
    line-height: 1.8;
    font-family: var(--font-serif);
    font-size: 1.05rem;
}

#modal-body ul {
    list-style: none;
    margin-bottom: var(--spacing-md);
}

#modal-body li {
    padding-left: var(--spacing-lg);
    position: relative;
    margin-bottom: var(--spacing-sm);
    color: var(--color-text-secondary);
}

#modal-body li::before {
    content: '✦';
    position: absolute;
    left: 0;
    color: var(--color-primary);
}

/* Calculation Display */
.calculation-display {
    background: rgba(139, 92, 246, 0.1);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--spacing-lg);
    margin-top: var(--spacing-md);
    font-family: 'Courier New', monospace;
    font-size: 0.9rem;
}

.calculation-display .calc-step {
    margin-bottom: var(--spacing-sm);
    padding: var(--spacing-xs) 0;
    color: var(--color-text-secondary);
}

.calculation-display .calc-result {
    color: var(--color-primary-light);
    font-weight: bold;
    margin-top: var(--spacing-sm);
    padding-top: var(--spacing-sm);
    border-top: 1px solid var(--color-border-light);
    font-size: 1rem;
}

/* Responsive */
@media (max-width: 768px) {
    .hero-features {
        grid-template-columns: repeat(2, 1fr);
    }
    .numbers-grid {
        grid-template-columns: repeat(2, 1fr);
    }
    .reading-tabs {
        gap: var(--spacing-xs);
    }
    .tab-button {
        font-size: 0.75rem;
        padding: var(--spacing-xs) var(--spacing-md);
    }
    .chakra-values {
        grid-template-columns: 1fr;
    }
    .chakra-totals {
        grid-template-columns: repeat(2, 1fr);
    }
    .chakra-header {
        flex-direction: column;
        text-align: center;
    }
    .astro-grid {
        grid-template-columns: 1fr;
    }
}

@media (max-width: 480px) {
    .hero-features {
        grid-template-columns: 1fr;
    }
    .numbers-grid {
        grid-template-columns: 1fr;
    }
    .date-inputs, .time-inputs {
        grid-template-columns: 1fr;
    }
    .action-buttons {
        flex-direction: column;
    }
    .action-button {
        width: 100%;
        justify-content: center;
    }
    .cta-buttons {
        flex-direction: column;
    }
    .cta-button {
        width: 100%;
        justify-content: center;
    }
}

@media print {
    .hero-section, .input-section, .compatibility-section, .reviews-section,
