        const steps = [`${month} + ${day} + ${year} = ${total}`];
        
        while (result > 9 && ![11, 22, 33].includes(result)) {
            const prev = result;
            result = result.toString().split('').reduce((a, b) => a + parseInt(b), 0);
            steps.push(`${prev} → ${result}`);
