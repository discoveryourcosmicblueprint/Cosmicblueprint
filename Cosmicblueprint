    getRisingSign(hour, month) {
        if (hour === null || hour === undefined) return null;
        const signs = Object.keys(ZODIAC_DATA);
        const index = (Math.floor(hour / 2) + month - 1) % 12;
        return signs[index];
    },
    
    calculatePersonalYear(month, day, currentYear) {
        const sum = month + day + currentYear.toString().split('').reduce((a, b) => a + parseInt(b), 0);
        return this.reduceNumber(sum, false);
