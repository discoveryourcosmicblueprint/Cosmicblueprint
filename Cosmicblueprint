    calculateCompatibility(calcs1, calcs2) {
        const getScore = (n1, n2) => {
            n1 = [11, 22, 33].includes(n1) ? n1 : this.reduceNumber(n1, false);
            n2 = [11, 22, 33].includes(n2) ? n2 : this.reduceNumber(n2, false);
            return COMPATIBILITY_MATRIX[n1]?.[n2] || 50;
        };
        
        const scores = {
            lifePath: getScore(calcs1.lifePath, calcs2.lifePath),
            destiny: getScore(calcs1.destiny, calcs2.destiny),
            soulUrge: getScore(calcs1.soulUrge, calcs2.soulUrge),
            personality: getScore(calcs1.personality, calcs2.personality)
        };
        
        // Zodiac compatibility
        const elements = { fire: ['aries','leo','sagittarius'], earth: ['taurus','virgo','capricorn'],
                          air: ['gemini','libra','aquarius'], water: ['cancer','scorpio','pisces'] };
        
        const getElement = sign => {
            for (const [el, signs] of Object.entries(elements)) {
                if (signs.includes(sign)) return el;
            }
            return null;
        };
        
        const el1 = getElement(calcs1.sunSign);
        const el2 = getElement(calcs2.sunSign);
        
        let zodiacScore = 50;
        if (el1 === el2) zodiacScore = 85;
        else if ((el1 === 'fire' && el2 === 'air') || (el1 === 'air' && el2 === 'fire')) zodiacScore = 80;
        else if ((el1 === 'earth' && el2 === 'water') || (el1 === 'water' && el2 === 'earth')) zodiacScore = 80;
        else if ((el1 === 'fire' && el2 === 'water') || (el1 === 'water' && el2 === 'fire')) zodiacScore = 40;
        else if ((el1 === 'earth' && el2 === 'air') || (el1 === 'air' && el2 === 'earth')) zodiacScore = 45;
        
        scores.zodiac = zodiacScore;
        
        const overall = Math.round(
            scores.lifePath * 0.30 + scores.destiny * 0.20 + 
            scores.soulUrge * 0.20 + scores.personality * 0.10 + scores.zodiac * 0.20
        );
        
        let level, description;
        if (overall >= 85) {
            level = "Exceptional";
            description = "Your energies harmonize beautifully. This is a rare and powerful connection.";
        } else if (overall >= 70) {
            level = "Strong";
            description = "You have natural compatibility with room for growth together.";
        } else if (overall >= 55) {
            level = "Moderate";
            description = "Workable compatibility that requires understanding of differences.";
        } else if (overall >= 40) {
            level = "Challenging";
            description = "Significant differences that can lead to growth with commitment.";
        } else {
            level = "Difficult";
            description = "Major differences requiring exceptional effort to bridge.";
        }
        
        return { overall, scores, level, description };
    },
    
    calculateAll(birthDate, name, birthTime = null) {
        const { month, day, year } = birthDate;
        const currentYear = new Date().getFullYear();
        
        const lifePathResult = this.calculateLifePath(month, day, year);
        const destiny = this.calculateFromName(name, 'all');
        const soulUrge = this.calculateFromName(name, 'vowels');
        const personality = this.calculateFromName(name, 'consonants');
        const birthday = this.reduceNumber(day, true);
        const maturity = this.reduceNumber(lifePathResult.number + destiny, true);
        
        const sunSign = this.getZodiacSign(month, day);
        const moonSign = this.getMoonSign(month, day, year);
        const risingSign = birthTime ? this.getRisingSign(birthTime.hour, month) : null;
        
        return {
            lifePath: lifePathResult.number,
            lifePathSteps: lifePathResult.steps,
            destiny,
            soulUrge,
            personality,
            birthday,
            birthdayRaw: day,
            maturity,
            personalYear: this.calculatePersonalYear(month, day, currentYear),
            destinyMatrix: this.calculateDestinyMatrix(month, day, year),
            chakras: this.calculateChakras(month, day, year),
            sunSign,
            moonSign,
            risingSign
        };
    },
    
    findPatterns(calcs) {
        const numbers = [calcs.lifePath, calcs.destiny, calcs.soulUrge, calcs.personality, calcs.birthday];
        const counts = {};
        const patterns = { masterNumbers: [], repeating: [], missing: [] };
        
        numbers.forEach(n => {
            if ([11, 22, 33].includes(n)) {
                patterns.masterNumbers.push(n);
            }
            const reduced = this.reduceNumber(n, false);
            counts[reduced] = (counts[reduced] || 0) + 1;
        });
        
        for (let i = 1; i <= 9; i++) {
            if (!counts[i]) patterns.missing.push(i);
            else if (counts[i] >= 2) patterns.repeating.push({ number: i, count: counts[i] });
        }
        
        patterns.repeating.sort((a, b) => b.count - a.count);
        return patterns;
    }
};

